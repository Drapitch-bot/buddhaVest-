{
  "expo": {
    "name": "BuddhaVest",
    "slug": "buddhavest",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/opening_monk.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.buddhavest.app"
    },
    "android": {
      "package": "com.buddhavest.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1c1f26"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser"
    ],
    "updates": {
      "url": "https://u.expo.dev/1c6dd877-b901-48af-95b6-b90dc3687954",
      "enabled": true,
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "privacyPolicyUrl": "https://buddhavest.onrender.com/privacy",
      "eas": {
        "projectId": "1c6dd877-b901-48af-95b6-b90dc3687954"
      }
    }
  }
}
